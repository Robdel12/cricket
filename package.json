{
  "name": "@robdel12/cricket",
  "version": "0.1.0",
  "type": "module",
  "description": "Tiny contracts for sturdy Node APIs.",
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "cricket": "./bin/cricket.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./app": "./src/app.js",
    "./domain": "./src/domain.js",
    "./jobs": "./src/jobs/index.js",
    "./knex": "./src/persistence/knex.js",
    "./logger": "./src/logger.js",
    "./openapi": "./src/openapi.js",
    "./serializer": "./src/serializer.js",
    "./test": "./src/test/index.js"
  },
  "scripts": {
    "cricket": "node bin/cricket.js",
    "test": "node --test",
    "test:redis": "node test-support/run-redis-tests.js",
    "check": "node --check bin/*.js src/*.js src/**/*.js test/*.test.js test/fixtures/*.js test-support/*.js integration/*.js fixtures/**/*.js examples/*.js",
    "prepublishOnly": "pnpm run check && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Robdel12/cricket.git"
  },
  "bugs": {
    "url": "https://github.com/Robdel12/cricket/issues"
  },
  "homepage": "https://github.com/Robdel12/cricket#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "knex": "^3.2.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2"
  }
}
